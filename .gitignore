# Corpora of real verbatims never enter the repo (working rule #6):
# they live here locally, for the pipeline spike and manual testing.
corpus/

# Terraform — state and provider caches never enter the repo
# (.terraform.lock.hcl IS committed: it pins provider hashes).
infra/terraform/**/.terraform/
infra/terraform/**/terraform.tfstate
infra/terraform/**/terraform.tfstate.*
infra/terraform/**/*.tfvars
