# Dev-only image: source code comes from the compose bind mount, so this
# image only carries uv, Python and the synced virtualenv. Rebuild it
# whenever dependencies change (make rebuild).
FROM ghcr.io/astral-sh/uv@sha256:0f36cb9361a3346885ca3677e3767016687b5a170c1a6b88465ec14aefec90aa

WORKDIR /app
RUN groupadd --system app && useradd --system --gid app --create-home app \
    && chown app:app /app
USER app

# Hardlinks cannot cross the volume boundary between uv's cache and .venv.
ENV UV_LINK_MODE=copy
# Tool caches land outside the bind mount: the source tree is not writable
# by this user on Linux hosts (CI runners).
ENV RUFF_CACHE_DIR=/home/app/.cache/ruff
ENV MYPY_CACHE_DIR=/home/app/.cache/mypy
ENV PYTEST_ADDOPTS="-p no:cacheprovider"

COPY --chown=app:app pyproject.toml uv.lock README.md ./
COPY --chown=app:app src src
RUN uv sync --frozen

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s \
  CMD ["/app/.venv/bin/python", "-c", "import os, sys; from ai_worker.database import is_database_ready; sys.exit(0 if is_database_ready(os.environ['DATABASE_URL']) else 1)"]

CMD ["uv", "run", "--frozen", "watchfiles", "--filter", "python", "uv run ai-worker", "src"]
