# Dev-only image: source code comes from the compose bind mount, so this
# image only carries the runtime and the installed dependencies. Rebuild it
# whenever package.json / package-lock.json change (make rebuild).
FROM node:26-alpine@sha256:e88a35be04478413b7c71c455cd9865de9b9360e1f43456be5951032d7ac1a66

WORKDIR /app
RUN chown node:node /app
USER node

COPY --chown=node:node package.json package-lock.json ./
RUN npm ci

EXPOSE 5173

# 127.0.0.1, not localhost: busybox wget resolves localhost to ::1 and Vite
# only listens on IPv4.
HEALTHCHECK --interval=30s --timeout=3s --start-period=15s \
  CMD wget -qO /dev/null http://127.0.0.1:5173 || exit 1

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
